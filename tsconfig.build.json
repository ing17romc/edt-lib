{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "outDir": "./dist",
    "rootDir": "./src",
    "types": []
  },
  "include": [
    "src/index.ts",
    "src/components/**/*",
    "src/declarations.d.ts"
  ],
  "exclude": [
    "src/**/*.stories.tsx",
    "src/**/*.test.tsx",
    "src/**/stories/**",
    "src/**/tests/**",
    "src/**/__tests__/**",
    "src/**/__mocks__/**",
    "src/Examples/**",
    "src/static/**",
    "src/setupTests.ts"
  ]
}
