{
  "name": "edt-lib",
  "version": "2.16.0",
  "description": "Front-end library, rebuilt for React",
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.es.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    }
  },
  "author": "ing romc",
  "license": "ISC",
  "homepage": "http://ing17romc.github.io/edt-lib/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ing17romc/edt-lib.git"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "clean": "rm package-lock.json && rm -rf node_modules && rm -rf .gh-pages && rm -rf storybook-static && rm -rf dist && npm i --force",
    "build": "vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:js": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" --fix",
    "lint:ts": "npx tsc --noEmit",
    "lint": "npm run lint:js && npm run lint:scss",
    "sb": "storybook dev -p 6006",
    "build-sb": "storybook build",
    "release-sb": "npm run build-sb && rm -rf .gh-pages && gh-pages -d storybook-static",
    "publish-npm-patch": "npm version patch && npm run build && npm publish --access public",
    "publish-npm-minor": "npm version minor && npm run build && npm publish --access public",
    "publish-npm-major": "npm version major && npm run build && npm publish --access public"
  },
  "dependencies": {
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "sass": "^1.89.2",
    "storybook": "^10.3.5",
    "stylelint": "^16.21.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  },
  "browserslist": {},
  "files": [
    "dist",
    "src/styles",
    "index.scss"
  ]
}
