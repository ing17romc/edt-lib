{
  "name": "edt-lib",
  "version": "2.20.0",
  "description": "React component library with Storybook docs, Sass styling, and SSR-safe theming primitives.",
  "type": "module",
  "main": "./dist/index.cjs.js",
  "module": "./dist/index.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.es.js",
      "require": "./dist/index.cjs.js"
    },
    "./styles.css": "./dist/styles.css",
    "./index.scss": "./index.scss",
    "./package.json": "./package.json"
  },
  "author": "ing romc",
  "license": "ISC",
  "homepage": "https://ing17romc.github.io/edt-lib/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ing17romc/edt-lib.git"
  },
  "bugs": {
    "url": "https://github.com/ing17romc/edt-lib/issues"
  },
  "keywords": [
    "react",
    "component-library",
    "design-system",
    "storybook",
    "vite",
    "sass",
    "typescript",
    "nextjs",
    "vercel"
  ],
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "clean": "node -e \"for (const target of ['.gh-pages', 'storybook-static', 'dist', '.tmp']) require('node:fs').rmSync(target, { recursive: true, force: true })\"",
    "clean:dist": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc --noEmit",
    "build:types": "tsc -p tsconfig.build.json",
    "build": "npm run clean:dist && npm run build:types && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:js": "eslint .",
    "lint:js:fix": "eslint . --fix",
    "lint:scss": "stylelint \"src/**/*.scss\" && node tools/check-scss-architecture.mjs",
    "lint:scss:fix": "stylelint \"src/**/*.scss\" --fix && node tools/check-scss-architecture.mjs",
    "lint:ts": "npm run typecheck",
    "lint": "npm run lint:js && npm run lint:scss && npm run lint:ts",
    "sb": "storybook dev -p 6006",
    "build-sb": "storybook build",
    "storybook": "npm run sb",
    "build:storybook": "npm run build-sb",
    "pack:check": "npm pack --dry-run",
    "smoke:package": "node scripts/smoke-package.mjs",
    "ci:verify": "npm run lint && npm run test && npm run build && npm run build-sb && npm run pack:check && npm run smoke:package",
    "release-sb": "npm run build-sb && node -e \"require('node:fs').rmSync('.gh-pages', { recursive: true, force: true })\" && gh-pages -d storybook-static",
    "publish-npm-patch": "npm version patch && npm run build && npm publish --access public",
    "publish-npm-minor": "npm version minor && npm run build && npm publish --access public",
    "publish-npm-major": "npm version major && npm run build && npm publish --access public"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/react-vite": "^10.3.5",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "gh-pages": "^6.3.0",
    "globals": "^17.4.0",
    "jsdom": "^29.0.1",
    "playwright": "^1.59.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "sass": "^1.89.2",
    "storybook": "^10.3.5",
    "stylelint": "^16.21.0",
    "stylelint-config-standard-scss": "^15.0.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.5",
    "vitest": "^4.1.2"
  },
  "sideEffects": [
    "**/*.css",
    "**/*.scss"
  ],
  "files": [
    "dist",
    "index.scss",
    "src/styles"
  ]
}
